{
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/.well-known/apple-app-site-association",
      "dest": "/.well-known/apple-app-site-association"
    },
    {
      "src": "/(.*)",
      "dest": "https://resolute-hoop-rank-flow.base44.app/$1"
    }
  ]
}
